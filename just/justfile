      ./gradlew "${gradle_module}:test"

gradle-module-clean-build module:
    @module='{{ module }}'; \
      module="${module#./}"; \
      module="${module%/}"; \
      if [[ -z "$module" ]]; then \
        echo "Module path is required" >&2; \
        exit 1; \
      fi; \
      gradle_module=":${module//\//:}"; \
      ./gradlew "${gradle_module}:clean" "${gradle_module}:build"
