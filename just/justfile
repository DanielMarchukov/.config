set shell := ["bash", "-uc"]

default:
    @just --list --unsorted

build: gradle-current-build

clean: gradle-current-clean

test: gradle-current-test

clean-build: gradle-current-clean-build

gradle-root-clean:
    ./gradlew clean

gradle-root-build:
    ./gradlew build

gradle-root-test:
    ./gradlew test

gradle-root-clean-build:
    ./gradlew clean build

gradle-current-clean:
    @root="$(pwd)"; \
      while [[ ! -f "$root/gradlew" && ! -f "$root/settings.gradle" && ! -f "$root/settings.gradle.kts" ]]; do \
        parent="$(dirname "$root")"; \
        if [[ "$parent" == "$root" ]]; then \
          echo "Not inside a Gradle project" >&2; \
          exit 1; \
        fi; \
        root="$parent"; \
      done; \
      module_dir="$(pwd)"; \
      while [[ "$module_dir" != "$root" && ! -f "$module_dir/build.gradle" && ! -f "$module_dir/build.gradle.kts" ]]; do \
        parent="$(dirname "$module_dir")"; \
        if [[ "$parent" == "$module_dir" ]]; then \
          echo "Could not resolve current Gradle module" >&2; \
          exit 1; \
        fi; \
        module_dir="$parent"; \
      done; \
      if [[ "$module_dir" == "$root" ]]; then \
        task="clean"; \
      else \
        rel="${module_dir#"$root"/}"; \
        task=":${rel//\//:}:clean"; \
      fi; \
      cd "$root"; \
      ./gradlew "$task"

gradle-current-build:
    @root="$(pwd)"; \
      while [[ ! -f "$root/gradlew" && ! -f "$root/settings.gradle" && ! -f "$root/settings.gradle.kts" ]]; do \
        parent="$(dirname "$root")"; \
        if [[ "$parent" == "$root" ]]; then \
          echo "Not inside a Gradle project" >&2; \
          exit 1; \
        fi; \
        root="$parent"; \
      done; \
      module_dir="$(pwd)"; \
      while [[ "$module_dir" != "$root" && ! -f "$module_dir/build.gradle" && ! -f "$module_dir/build.gradle.kts" ]]; do \
        parent="$(dirname "$module_dir")"; \
        if [[ "$parent" == "$module_dir" ]]; then \
          echo "Could not resolve current Gradle module" >&2; \
          exit 1; \
        fi; \
        module_dir="$parent"; \
      done; \
      if [[ "$module_dir" == "$root" ]]; then \
        task="build"; \
      else \
        rel="${module_dir#"$root"/}"; \
        task=":${rel//\//:}:build"; \
      fi; \
      cd "$root"; \
      ./gradlew "$task"

gradle-current-test:
    @root="$(pwd)"; \
      while [[ ! -f "$root/gradlew" && ! -f "$root/settings.gradle" && ! -f "$root/settings.gradle.kts" ]]; do \
        parent="$(dirname "$root")"; \
        if [[ "$parent" == "$root" ]]; then \
