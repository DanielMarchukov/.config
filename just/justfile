gradle-current-clean-build:
    @root="$(pwd)"; \
      while [[ ! -f "$root/gradlew" && ! -f "$root/settings.gradle" && ! -f "$root/settings.gradle.kts" ]]; do \
        parent="$(dirname "$root")"; \
        if [[ "$parent" == "$root" ]]; then \
          echo "Not inside a Gradle project" >&2; \
          exit 1; \
        fi; \
        root="$parent"; \
      done; \
      module_dir="$(pwd)"; \
      while [[ "$module_dir" != "$root" && ! -f "$module_dir/build.gradle" && ! -f "$module_dir/build.gradle.kts" ]]; do \
        parent="$(dirname "$module_dir")"; \
        if [[ "$parent" == "$module_dir" ]]; then \
          echo "Could not resolve current Gradle module" >&2; \
          exit 1; \
        fi; \
        module_dir="$parent"; \
      done; \
      if [[ "$module_dir" == "$root" ]]; then \
        clean_task="clean"; \
        build_task="build"; \
      else \
        rel="${module_dir#"$root"/}"; \
        clean_task=":${rel//\//:}:clean"; \
        build_task=":${rel//\//:}:build"; \
      fi; \
      cd "$root"; \
      ./gradlew "$clean_task" "$build_task"

gradle-module-clean module:
    @module='{{ module }}'; \
      module="${module#./}"; \
      module="${module%/}"; \
      if [[ -z "$module" ]]; then \
        echo "Module path is required" >&2; \
        exit 1; \
      fi; \
      gradle_module=":${module//\//:}"; \
      ./gradlew "${gradle_module}:clean"

gradle-module-build module:
    @module='{{ module }}'; \
      module="${module#./}"; \
      module="${module%/}"; \
      if [[ -z "$module" ]]; then \
        echo "Module path is required" >&2; \
        exit 1; \
      fi; \
      gradle_module=":${module//\//:}"; \
      ./gradlew "${gradle_module}:build"

